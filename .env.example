# Lagos Bio-Design Bootcamp - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# ========================================
# Supabase Configuration
# ========================================
# Get these from: https://app.supabase.com > Your Project > Settings > API

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to use in browser)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ========================================
# Application Configuration
# ========================================

# Access code for cohort registration
# This should be shared privately with approved participants
VITE_ACCESS_CODE=YOUR-SECRET-CODE-HERE

# ========================================
# Optional: Environment Identifier
# ========================================

# Environment (development, staging, production)
VITE_ENV=development

# ========================================
# Optional: Error Monitoring (Sentry)
# ========================================

# Sentry DSN for error tracking (production only)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ========================================
# Notes
# ========================================
# 1. Rename this file to .env
# 2. Fill in all REQUIRED values
# 3. Keep .env in your .gitignore
# 4. Use different keys for dev/staging/production
# 5. Rotate keys every 90 days for security
